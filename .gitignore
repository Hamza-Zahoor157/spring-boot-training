# Build output
target/
build/
out/
*.class

# Maven Wrapper binary (the scripts and properties file stay tracked)
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Local configuration and secrets
# application.yaml is intentionally tracked: it must contain placeholders only.
.env
.env.*
!.env.example
src/main/resources/application-local.yaml
src/main/resources/application-local.yml
*.pem
*.key
*.p12
*.pfx
secrets/

